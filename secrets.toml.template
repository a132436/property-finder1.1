# ─────────────────────────────────────────────────────────────────────────────
# Property Finder — Secrets Template
#
# DO NOT commit this file to GitHub. It is listed in .gitignore.
#
# When deploying to Streamlit Community Cloud, add these values via:
# App Settings → Secrets (in the Streamlit dashboard)
#
# Paste the contents of this file there and fill in your real keys.
# ─────────────────────────────────────────────────────────────────────────────

# Your Apify API token
# Find it at: https://console.apify.com/account/integrations
APIFY_API_TOKEN = "apify_api_PASTE_YOUR_TOKEN_HERE"

# Your Anthropic (Claude) API key
# Find it at: https://console.anthropic.com/api-keys
ANTHROPIC_API_KEY = "sk-ant-PASTE_YOUR_KEY_HERE"

# Your Google Maps API key (with Distance Matrix API enabled)
# Find it at: https://console.cloud.google.com/apis/credentials
GOOGLE_MAPS_API_KEY = "PASTE_YOUR_GOOGLE_MAPS_KEY_HERE"
